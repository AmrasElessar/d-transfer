{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DTransfer",
  "version": "0.1.0",
  "identifier": "dev.dbrand.dtransfer",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DTransfer",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": true,
        "resizable": true,
        "fullscreen": false,
        "transparent": false,
        "theme": null
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Deterministic, crash-resilient transfer client",
    "longDescription": "DTransfer is a deterministic, crash-resilient file transfer infrastructure client supporting SFTP, S3, and WebDAV with client-side encryption, atomic resume, and persistent transfer queues."
  }
}
